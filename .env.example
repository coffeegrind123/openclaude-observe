# Server
CLAUDE_OBSERVE_SERVER_PORT=4981   # Port used by local dev & docker container
CLAUDE_OBSERVE_LOG_LEVEL=debug    # debug | trace
CLAUDE_OBSERVE_DB_PATH=../../data/observe.db
# CLAUDE_OBSERVE_STORAGE_ADAPTER=sqlite
# CLAUDE_OBSERVE_WEBSOCKET=true
# CLAUDE_OBSERVE_CLIENT_DIST_PATH=       # Path to built client assets (production only)

# Client (Vite dev server)
CLAUDE_OBSERVE_CLIENT_PORT=5174          # Only relevant for local dev

# Plugin / CLI overrides (optional)
# CLAUDE_OBSERVE_API_BASE_URL=http://127.0.0.1:4981/api   # Override API base URL used by observe_cli.mjs
# CLAUDE_OBSERVE_DOCKER_CONTAINER_NAME=claude-observe      # Docker container name
# CLAUDE_OBSERVE_DOCKER_IMAGE=ghcr.io/simple10/claude-observe:v0.5.0  # Docker image to pull/run
