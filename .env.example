# Env vars for OpenClaude Observe
#
# All server config is centralized in app/server/src/config.ts — every var
# below (except AGENTS_OBSERVE_DATA_DIR, which is compose-only) is read there.
#
# Copy to .env at the repo root to override defaults for `just dev`, `just
# start-local`, or `docker compose up openclaude-observe`. In a worktree,
# give each copy its own ports.

# ── Server ──────────────────────────────────────────────
AGENTS_OBSERVE_SERVER_PORT=4981            # API + UI port (also exposed by Docker)
AGENTS_OBSERVE_LOG_LEVEL=warn              # warn | debug | trace
AGENTS_OBSERVE_RUNTIME=docker              # docker | local | dev
AGENTS_OBSERVE_SHUTDOWN_DELAY_MS=30000     # Auto-shutdown after last consumer disconnects; 0 disables

# ── Data ────────────────────────────────────────────────
AGENTS_OBSERVE_DB_PATH=data/observe.db     # SQLite database path (inside the container: /data/observe.db)
AGENTS_OBSERVE_ALLOW_DB_RESET=backup       # allow | backup | deny — policy for DELETE /api/data
# AGENTS_OBSERVE_STORAGE_ADAPTER=sqlite    # Storage backend (currently only sqlite)

# ── Dev-mode only (just dev) ────────────────────────────
AGENTS_OBSERVE_DEV_CLIENT_PORT=5174        # Vite dev server port for the dashboard UI

# ── Docker compose only ─────────────────────────────────
# AGENTS_OBSERVE_DATA_DIR=./data           # Host directory bind-mounted into the container at /data
# AGENTS_OBSERVE_CLIENT_DIST_PATH=         # Override the client dist directory (normally auto-detected)
