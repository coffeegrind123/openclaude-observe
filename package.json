{
  "name": "openclaude-observe",
  "version": "18.04.2026",
  "description": "Real-time observability dashboard for Claude Code agents",
  "license": "MIT",
  "repository": "https://github.com/coffeegrind123/openclaude-observe",
  "homepage": "https://github.com/coffeegrind123/openclaude-observe",
  "private": true,
  "scripts": {
    "start": "node start.mjs",
    "test": "cd app/server && npm test && cd ../client && npm test",
    "test:server:watch": "cd app/server && npm run test:watch",
    "test:client:watch": "cd app/client && npm run test:watch",
    "fmt": "npx prettier --write 'app/server/src/**/*.ts' 'app/client/src/**/*.{ts,tsx}' 'test/**/*.mjs' 'start.mjs'",
    "check": "npm test && npm run fmt"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
